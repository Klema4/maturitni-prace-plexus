############################################
# Plexus — ukázková konfigurace prostředí
#
# Doporučení:
# - pro lokální vývoj zkopírujte obash souboru do nového souboru `.env`
# - `.env` necommitujte veřejně (obsahuje tajemství a citlivé údaje)
############################################

############################################
# Základní URL aplikace
############################################

# Veřejná URL webu (používá se např. pro sitemap a odkazy v emailech)
SITE_URL="http://localhost:3000"

# Veřejná URL pro client-side (používá RSS + redirect na náhodný článek)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Better Auth base URL (server-side). Pokud není, bere se SITE_URL.
BETTER_AUTH_URL="http://localhost:3000"

# Better Auth base URL (client-side). Pokud není, bere se NEXT_PUBLIC_SITE_URL.
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# Client-side URL webu (fallback pro auth klienta)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

############################################
# Databáze (Neon Postgres)
############################################

# Např. "postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DATABASE_URL=""

############################################
# Better Auth
############################################

# Minimálně 32 znaků. V produkci vždy potřeba nastavit pro bezpečné šifrování a podepisování.
BETTER_AUTH_SECRET="change-me-in-production-min-32-chars"

############################################
# Email (Plunk transactional)
############################################

# Secret Key (sk_*) z Plunk účtu (pokud není, emaily se jen zalogují a neodešlou).
# Plunk dokumentace: `https://docs.useplunk.com/api-reference/overview`
PLUNK_SECRET_KEY=""

# Zpětná kompatibilita (deprecated): starší název proměnné.
# Pokud nastavíš PLUNK_SECRET_KEY, PLUNK_API_KEY už nepotřebuješ.
PLUNK_API_KEY=""

############################################
# Upload/Storage (MinIO / RustFS / S3 kompatibilní)
############################################

# Hostname nebo URL. Pokud nastavíte i port+ssl, složí se URL automaticky.
MINIO_ENDPOINT="http://127.0.0.1"
MINIO_PORT="9000"
MINIO_USE_SSL="false"

MINIO_REGION="us-east-1"
MINIO_ACCESS_KEY=""
MINIO_SECRET_KEY=""

# Výchozí bucket pro ukládání souborů (kód používá fallback "files")
MINIO_BUCKET_NAME="files"

# Veřejná URL pro sestavení fileUrl na frontendu (pokud BetterUpload nevrátí přímé URL)
# Příklad: "http://127.0.0.1:9000"
NEXT_PUBLIC_MINIO_PUBLIC_URL="http://127.0.0.1:9000"

############################################
# Šifrování tajných hodnot uložených v DB
############################################

# 32 bytů v base64 (AES-256-GCM master key).
# Vygenerujete např.: `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`
SECRETS_ENCRYPTION_KEY_BASE64=""

############################################
# Vercel (volitelné)
############################################

# Používá se jako fallback pro sitemap siteUrl.
# Vercel to obvykle poskytuje sám (nemusíte nastavovat lokálně).
VERCEL_URL=""

